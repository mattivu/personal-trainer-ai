generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int               @id @default(autoincrement())
  email             String            @unique
  passwordHash      String
  name              String?
  role              String            @default("user")
  onboardingStatus  String            @default("not_started")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  profile           UserProfile?
  sessions          UserSession[]
  onboardingAnswers OnboardingAnswer[]
  trainingPrograms  TrainingProgram[]
  workoutLogs       WorkoutLog[]

  @@map("users")
}

model OnboardingAnswer {
  id          Int       @id @default(autoincrement())
  userId      Int
  step        String
  answersJson Json
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, step])
  @@map("onboarding_answers")
}

model UserSession {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model UserProfile {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  birthDate      DateTime?
  sex            String?
  heightCm       Int?
  startingWeight Float?
  mainGoal       String?
  experience     String?
  trainingPlace  String?
  availableDays  String?
  equipment      String?  @db.Text
  limitations    String?  @db.Text
  lifestyle      String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model Exercise {
  id                 Int               @id @default(autoincrement())
  name               String
  slug               String            @unique
  category           String
  primaryMuscle      String
  secondaryMuscles   Json?
  equipment          String?
  difficulty         String?
  movementPattern    String?
  environments       Json?
  tags               Json?
  alternatives       Json?
  instructions       String?           @db.Text
  contraindications  Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  programExercises   ProgramExercise[]

  @@map("exercises")
}

model TrainingProgram {
  id          Int              @id @default(autoincrement())
  userId      Int
  title       String
  goal        String?
  status      String           @default("active")
  source      String           @default("manual")
  startDate   DateTime?
  endDate     DateTime?
  durationWeeks Int?
  startedAt   DateTime?
  plannedReviewAt DateTime?
  onboardingSnapshotHash String?
  revisionReason String?
  notes       String?          @db.Text
  safetyNotes Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workouts    ProgramWorkout[]
  workoutLogs WorkoutLog[]

  @@index([userId])
  @@index([status])
  @@map("training_programs")
}

model ProgramWorkout {
  id               Int               @id @default(autoincrement())
  programId        Int
  title            String
  dayLabel         String?
  focus            String?
  sortOrder        Int               @default(0)
  estimatedMinutes Int?
  notes            String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  program          TrainingProgram   @relation(fields: [programId], references: [id], onDelete: Cascade)
  exercises        ProgramExercise[]
  workoutLogs      WorkoutLog[]

  @@index([programId])
  @@map("program_workouts")
}

model ProgramExercise {
  id                         Int             @id @default(autoincrement())
  workoutId                  Int
  exerciseId                 Int?
  name                       String
  sortOrder                  Int             @default(0)
  sets                       Int?
  reps                       String?
  restSeconds                Int?
  tempo                      String?
  intensity                  String?
  notes                      String?         @db.Text
  alternatives               Json?
  isActive                   Boolean         @default(true)
  replacedAt                 DateTime?
  replacedByProgramExerciseId Int?
  replacementReason          String?         @db.Text
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt

  workout                    ProgramWorkout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise                   Exercise?       @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  setLogs                    WorkoutSetLog[]

  @@index([workoutId])
  @@index([exerciseId])
  @@index([workoutId, isActive, sortOrder])
  @@index([replacedByProgramExerciseId])
  @@map("program_exercises")
}

model WorkoutLog {
  id               Int              @id @default(autoincrement())
  userId           Int
  programId        Int?
  workoutId        Int?
  performedAt      DateTime         @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  status           String           @default("completed")
  durationMinutes  Int?
  perceivedEffort  Int?
  notes            String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  program          TrainingProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  workout          ProgramWorkout?  @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  setLogs          WorkoutSetLog[]

  @@index([userId])
  @@index([programId])
  @@index([workoutId])
  @@map("workout_logs")
}

model WorkoutSetLog {
  id                Int              @id @default(autoincrement())
  workoutLogId      Int
  programExerciseId Int?
  setNumber         Int
  plannedReps       String?
  actualReps        Int?
  weightKg          Float?
  rir               Int?
  rpe               Int?
  completed         Boolean          @default(true)
  notes             String?          @db.Text
  createdAt         DateTime         @default(now())

  workoutLog        WorkoutLog       @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  programExercise   ProgramExercise? @relation(fields: [programExerciseId], references: [id], onDelete: SetNull)

  @@index([workoutLogId])
  @@index([programExerciseId])
  @@map("workout_set_logs")
}
